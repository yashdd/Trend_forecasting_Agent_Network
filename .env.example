# Database (override if not using docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trend_analyzer
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/trend_analyzer

# Reddit API - create app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendForecastingAgent/1.0

# GitHub personal access token (optional, raises rate limit from 10 to 30 req/min)
GITHUB_TOKEN=

# Product Hunt API v2 developer token - https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_API_TOKEN=

# Google Gemini for Synthesis agent (set GOOGLE_API_KEY in .env)
GOOGLE_API_KEY=
# Gemini model (1.5-flash/pro are deprecated; use 2.x): gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro
GEMINI_MODEL=gemini-2.0-flash

# Embedding model (sentence-transformers)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Optional
DEBUG=false
PIPELINE_TOP_K_SYNTHESIS=10
PIPELINE_BATCH_SIZE_EMBED=64

# Optional Databricks background scheduler (no user UI needed)
USE_DATABRICKS_JOBS=false
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_PIPELINE_JOB_ID=
